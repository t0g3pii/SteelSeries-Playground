{
  "name": "steelseries-playground",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c orange,cyan \"npm run dev --workspace=@gamedac/server\" \"npm run dev --workspace=@gamedac/web\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run start --workspace=@gamedac/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
